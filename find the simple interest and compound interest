#include<stdio.h>
int main()
{
int p,n,r,ci,si;
printf("enter principal amount:");
scanf("%d",&p);
printf("enter the time:");
scanf("%d",&n);
printf("enter the rate");
scanf("%d",&r);
si=(p*n*r)/100;
ci=p*(1+(r/100)^n)-p;
printf("the simple_interest is",si);
printf("the compound_interest is",ci);
return 0;
}
