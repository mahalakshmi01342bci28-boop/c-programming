#include<stdio.h>
int main()
{
   int c,f;
   printf("enter the temperature in celcius:");
   scanf("%d",&c);
   f=(c*9/5)+32;
   printf("%d degree celcius is equal to %d degree fahrenheit\n",c,f);
   printf("enter the temperature in fahrenheit:");
   scanf("%d",&f);
   c=(f-32)*5/9;
   printf("%d degree fahrenheit is equal to %d degree celsius\n",f,c);
   return 0;
}
